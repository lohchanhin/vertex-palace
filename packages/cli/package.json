{
  "name": "@vertex-palace/cli",
  "version": "0.1.6",
  "description": "Vertex Palace command line interface.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "palace": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
