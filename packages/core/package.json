{
  "name": "@vertex-palace/core",
  "version": "0.2.2",
  "description": "Core Vertex Palace adaptive scanner, router, packer, and guarded-memory engine.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
