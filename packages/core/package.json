  },
  "dependencies": {
    "@vertex-palace/shared": "workspace:*",
    "fast-glob": "^3.3.3",
    "ignore": "^5.3.2",
    "picocolors": "^1.1.1",
    "ts-morph": "^24.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
