{
  "name": "@context-palace/mcp",
  "version": "0.1.0",
  "description": "Context Palace MCP stdio server.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "context-palace-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "build": "tsup src/server.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@context-palace/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
