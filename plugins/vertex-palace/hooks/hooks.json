{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/session-start.js",
            "statusMessage": "Checking Vertex Palace status"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/stop.js",
            "statusMessage": "Updating Vertex Palace memory"
          }
        ]
      }
    ]
  }
}
